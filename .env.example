# URL do projeto Supabase (Project Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Chave anônima/pública do Supabase (Project Settings > API > anon public)
# Como a aplicação não tem login, esta chave fica exposta no navegador —
# por isso a tabela usa políticas de RLS abertas (ver supabase/migrations/0001_init.sql).
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
